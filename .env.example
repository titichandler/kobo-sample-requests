# Neon Postgres connection string (same database as the Streamlit app, or a fresh one)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Reviewer login (protects /requests — not committed; set in .env.local and on Vercel)
REVIEWER_PASSWORD=your-team-password
AUTH_SECRET=generate-with-node-crypto-randomBytes-32-base64

# Resend — shipment confirmation emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
# No quotes in Vercel — paste exactly: Kobo Samples <samples@requestsample.co.uk>
RESEND_FROM=Kobo Samples <samples@requestsample.co.uk>
# Optional override for new-request team alerts (comma-separated)
# REQUEST_NOTIFY_EMAILS=udhamnaskar@koboproductsinc.com,SNg@koboproductsinc.com,TChandler@koboproductsinc.com
