# Neon Postgres connection string (same database as the Streamlit app, or a fresh one)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Reviewer login (protects /requests — not committed; set in .env.local and on Vercel)
REVIEWER_PASSWORD=your-team-password
AUTH_SECRET=generate-with-node-crypto-randomBytes-32-base64

# Resend — shipment confirmation emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
# Must be a verified sender in Resend, e.g. "Kobo Samples <samples@yourdomain.com>"
RESEND_FROM="Kobo Samples <onboarding@resend.dev>"
